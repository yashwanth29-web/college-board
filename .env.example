# Django Settings
# Set to False in production for security
DEBUG=False

# CRITICAL: Change this to a strong random string in production
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-change-in-production

# Comma-separated list of allowed hostnames/domains
ALLOWED_HOSTS=localhost,127.0.0.1,portal.college.edu

# Database Configuration
# PostgreSQL password for the database container
DB_PASSWORD=secure_password_here

# CORS Configuration
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://portal.college.edu

# JWT Configuration (optional - uses SECRET_KEY if not set)
# JWT_SECRET_KEY=your-jwt-secret-key-here
